{
  "manifest_version": 3,
  "name": "MSF ISO-8 Counter/Assist Viewer",
  "version": "2.9.46",
  "description": "Displays ISO-8 Counter Attack/Assist ability information on Marvel Strike Force character pages",
  "content_scripts": [
    {
      "matches": ["https://marvelstrikeforce.com/*/characters/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": ["https://raw.githubusercontent.com/*"],
  "web_accessible_resources": [
    {
      "resources": ["locales.json"],
      "matches": ["https://marvelstrikeforce.com/*"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
